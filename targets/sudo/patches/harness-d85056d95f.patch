@@ -140,6 +141,7 @@ main(int argc, char *argv[], char *envp[])
     struct plugin_container *plugin, *next;
     sigset_t mask;
     debug_decl_vars(main, SUDO_DEBUG_MAIN)
+    __ROSA_TRACE_START();
 
