--- a/src/sudo.c
+++ b/src/sudo.c
@@ -68,6 +68,7 @@
 #include "sudo.h"
 #include "sudo_plugin.h"
 #include "sudo_plugin_int.h"
+#include "/root/rosa/fuzzers/aflpp/rosa-trace.h"
 
 /*
